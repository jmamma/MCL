    "mappings": {
      "record": "record",
      "play": "play",
      "stop": "stop",
      "func": "func",
      "up": "up",
      "left": "left",
      "down": "down",
      "right": "right",
      "enter": "button4",
      "escape": "button1",
      "scale": "scale",
      "bank_group": "page",
      "bankgroup": "page",
      "page": "page",
      "global": "global",
      "patsong": "patsong",
      "trig_1..16": "trig_1..16",
      "func_trig_1..16": "trig_1..16"
